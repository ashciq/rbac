{
  "version": "3.0",

  "actions": [
    "read", "list", "create", "update", "delete",
    "upload", "download", "approve", "assign",
    "archive", "manage"
  ],

  "scopes": {
    "subscription": {
      "description": "Organization/subscription-level permissions"
    },
    "project": {
      "description": "Project-level permissions (scoped per project)"
    }
  },

  "resources": {
    "projects": {
      "description": "Construction projects",
      "scope": "subscription",
      "allowed_actions": ["read", "list", "create", "update", "delete", "archive", "manage"]
    },
    "project_settings": {
      "description": "Project configuration, timezone, details",
      "scope": "project",
      "allowed_actions": ["read", "update", "manage"]
    },
    "submittals": {
      "description": "Submittal log entries",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete", "upload", "download", "approve", "assign", "archive"]
    },
    "materials": {
      "description": "Material tracking entries",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete", "upload", "download", "approve", "assign", "archive"]
    },
    "material_dateblock": {
      "description": "Material date block offsets, projected/actual/planned dates",
      "scope": "project",
      "allowed_actions": ["read", "update"]
    },
    "material_characteristics": {
      "description": "Material characteristics and properties",
      "scope": "project",
      "allowed_actions": ["read", "update"]
    },
    "material_templates": {
      "description": "Material date block templates",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete", "manage"]
    },
    "material_comments": {
      "description": "Comments on materials",
      "scope": "project",
      "allowed_actions": ["read", "create", "delete"]
    },
    "bid_packages": {
      "description": "Bid packages for procurement",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete"]
    },
    "design_packages": {
      "description": "Design packages",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete"]
    },
    "schedules": {
      "description": "Project schedules and activities",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete", "upload", "manage"]
    },
    "attachments": {
      "description": "File attachments on submittals and materials",
      "scope": "project",
      "allowed_actions": ["read", "upload", "download", "delete"]
    },
    "spec_sections": {
      "description": "Specification section files",
      "scope": "project",
      "allowed_actions": ["read", "upload", "delete"]
    },
    "workflows": {
      "description": "Submittal and material workflows",
      "scope": "project",
      "allowed_actions": ["read", "update", "approve", "manage"]
    },
    "workflow_templates": {
      "description": "Workflow template configuration",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete", "manage"]
    },
    "project_users": {
      "description": "Users assigned to a project",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete", "assign", "manage"]
    },
    "trade_partners": {
      "description": "Trade partner / subcontractor companies",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete"]
    },
    "distribution_groups": {
      "description": "Notification distribution groups",
      "scope": "project",
      "allowed_actions": ["read", "list", "create", "update", "delete"]
    },
    "calendars": {
      "description": "Project calendars and holidays",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete", "manage"]
    },
    "locations": {
      "description": "Location breakdown structure (LBS)",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete"]
    },
    "linking": {
      "description": "Linking between submittals, materials, and schedule activities",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete"]
    },
    "risk_reports": {
      "description": "Risk analysis reports",
      "scope": "project",
      "allowed_actions": ["read", "download", "manage"]
    },
    "risk_thresholds": {
      "description": "Risk threshold configuration",
      "scope": "project",
      "allowed_actions": ["read", "update"]
    },
    "custom_reports": {
      "description": "Custom report configurations",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete", "manage"]
    },
    "saved_views": {
      "description": "Saved grid/filter views",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete", "manage"]
    },
    "integrations": {
      "description": "External integrations (Autodesk ACC, Procore, CMiC)",
      "scope": "project",
      "allowed_actions": ["read", "create", "update", "delete", "manage"]
    },
    "lead_time_requests": {
      "description": "Lead time requests to subcontractors",
      "scope": "project",
      "allowed_actions": ["read", "create", "approve"]
    },
    "audit_logs": {
      "description": "System audit trail",
      "scope": "subscription",
      "allowed_actions": ["read", "list", "download"]
    },
    "subscription_users": {
      "description": "Subscription-level user management",
      "scope": "subscription",
      "allowed_actions": ["read", "list", "create", "update", "delete", "manage"]
    },
    "subscription_settings": {
      "description": "Subscription configuration and billing",
      "scope": "subscription",
      "allowed_actions": ["read", "update", "manage"]
    },
    "companies": {
      "description": "Company/organization management",
      "scope": "subscription",
      "allowed_actions": ["read", "list", "create", "update", "delete"]
    }
  },

  "permission_dependencies": {
    "manage:projects":             ["read:projects", "list:projects", "create:projects", "update:projects"],
    "manage:project_settings":     ["read:project_settings", "update:project_settings"],
    "delete:submittals":           ["read:submittals", "list:submittals"],
    "approve:submittals":          ["read:submittals"],
    "assign:submittals":           ["read:submittals", "list:submittals"],
    "upload:submittals":           ["read:submittals"],
    "archive:submittals":          ["read:submittals", "list:submittals"],
    "delete:materials":            ["read:materials", "list:materials"],
    "approve:materials":           ["read:materials"],
    "assign:materials":            ["read:materials", "list:materials"],
    "upload:materials":            ["read:materials"],
    "archive:materials":           ["read:materials", "list:materials"],
    "update:material_dateblock":   ["read:material_dateblock"],
    "update:material_characteristics": ["read:material_characteristics"],
    "manage:material_templates":   ["read:material_templates", "create:material_templates", "update:material_templates"],
    "manage:schedules":            ["read:schedules", "list:schedules", "upload:schedules"],
    "upload:attachments":          ["read:attachments"],
    "delete:attachments":          ["read:attachments"],
    "manage:workflows":            ["read:workflows", "update:workflows"],
    "manage:workflow_templates":   ["read:workflow_templates", "create:workflow_templates", "update:workflow_templates"],
    "manage:project_users":        ["read:project_users", "list:project_users", "create:project_users", "assign:project_users"],
    "manage:calendars":            ["read:calendars", "create:calendars", "update:calendars"],
    "manage:risk_reports":         ["read:risk_reports", "download:risk_reports"],
    "manage:custom_reports":       ["read:custom_reports", "create:custom_reports", "update:custom_reports"],
    "manage:saved_views":          ["read:saved_views", "create:saved_views", "update:saved_views"],
    "manage:integrations":         ["read:integrations", "create:integrations", "update:integrations"],
    "manage:subscription_users":   ["read:subscription_users", "list:subscription_users", "create:subscription_users", "update:subscription_users"],
    "manage:subscription_settings":["read:subscription_settings", "update:subscription_settings"]
  },

  "roles": {
    "subscription_viewer": {
      "description": "Read-only access at subscription level",
      "scope": "subscription",
      "inherits": [],
      "permissions": {
        "projects":               ["read", "list"],
        "subscription_users":     ["read", "list"],
        "subscription_settings":  ["read"],
        "companies":              ["read", "list"],
        "audit_logs":             ["read", "list"]
      }
    },
    "subscription_editor": {
      "description": "Can edit subscription resources but not full admin",
      "scope": "subscription",
      "inherits": ["subscription_viewer"],
      "permissions": {
        "projects":               ["create", "update"],
        "subscription_users":     ["create", "update"],
        "companies":              ["create", "update"]
      }
    },
    "subscription_admin": {
      "description": "Full subscription management",
      "scope": "subscription",
      "inherits": ["subscription_editor"],
      "permissions": {
        "projects":               ["delete", "archive", "manage"],
        "subscription_users":     ["delete", "manage"],
        "subscription_settings":  ["update", "manage"],
        "companies":              ["delete"],
        "audit_logs":             ["download"]
      }
    },

    "gc_project_admin": {
      "description": "General Contractor Project Admin - full project control",
      "scope": "project",
      "user_type": "general_contractor",
      "inherits": [],
      "permissions": {
        "project_settings":          ["read", "update", "manage"],
        "submittals":                ["read", "list", "create", "update", "delete", "upload", "download", "approve", "assign", "archive"],
        "materials":                 ["read", "list", "create", "update", "delete", "upload", "download", "approve", "assign", "archive"],
        "material_dateblock":        ["read", "update"],
        "material_characteristics":  ["read", "update"],
        "material_templates":        ["read", "create", "update", "delete", "manage"],
        "material_comments":         ["read", "create", "delete"],
        "bid_packages":              ["read", "list", "create", "update", "delete"],
        "design_packages":           ["read", "list", "create", "update", "delete"],
        "schedules":                 ["read", "list", "create", "update", "delete", "upload", "manage"],
        "attachments":               ["read", "upload", "download", "delete"],
        "spec_sections":             ["read", "upload", "delete"],
        "workflows":                 ["read", "update", "approve", "manage"],
        "workflow_templates":        ["read", "create", "update", "delete", "manage"],
        "project_users":             ["read", "list", "create", "update", "delete", "assign", "manage"],
        "trade_partners":            ["read", "list", "create", "update", "delete"],
        "distribution_groups":       ["read", "list", "create", "update", "delete"],
        "calendars":                 ["read", "create", "update", "delete", "manage"],
        "locations":                 ["read", "create", "update", "delete"],
        "linking":                   ["read", "create", "update", "delete"],
        "risk_reports":              ["read", "download", "manage"],
        "risk_thresholds":           ["read", "update"],
        "custom_reports":            ["read", "create", "update", "delete", "manage"],
        "saved_views":               ["read", "create", "update", "delete", "manage"],
        "integrations":              ["read", "create", "update", "delete", "manage"],
        "lead_time_requests":        ["read", "create", "approve"]
      }
    },
    "gc_foreman": {
      "description": "General Contractor Foreman - view + limited field actions",
      "scope": "project",
      "user_type": "general_contractor",
      "inherits": [],
      "permissions": {
        "project_settings":          ["read"],
        "submittals":                ["read", "list", "download"],
        "materials":                 ["read", "list", "download"],
        "material_dateblock":        ["read"],
        "material_characteristics":  ["read"],
        "material_templates":        ["read"],
        "material_comments":         ["read", "create"],
        "bid_packages":              ["read", "list"],
        "design_packages":           ["read", "list"],
        "schedules":                 ["read", "list"],
        "attachments":               ["read", "download"],
        "spec_sections":             ["read"],
        "workflows":                 ["read"],
        "workflow_templates":        ["read"],
        "project_users":             ["read", "list"],
        "trade_partners":            ["read", "list"],
        "distribution_groups":       ["read", "list"],
