{
  "version": "3.0",

  "actions": [
    "read", "list", "create", "update", "delete",
    "upload", "download", "approve", "assign",
    "archive", "manage"
  ],

  "resources": {
    "dashboard": {
      "description": "Analytics dashboard",
      "allowed_actions": ["read", "manage"]
    },
    "orders": {
      "description": "Customer orders",
      "allowed_actions": ["read", "list", "create", "update", "delete", "download", "approve", "assign", "archive"]
    },
    "invoices": {
      "description": "Financial invoices",
      "allowed_actions": ["read", "list", "create", "update", "delete", "download", "approve"]
    },
    "reports": {
      "description": "Business reports",
      "allowed_actions": ["read", "list", "create", "update", "delete", "upload", "download"]
    },
    "documents": {
      "description": "Document storage",
      "allowed_actions": ["read", "list", "create", "update", "delete", "upload", "download", "archive"]
    },
    "projects": {
      "description": "Project workspaces",
      "allowed_actions": ["read", "list", "create", "update", "delete", "archive", "manage"]
    },
    "users": {
      "description": "User accounts",
      "allowed_actions": ["read", "list", "create", "update", "delete", "assign", "manage"]
    },
    "settings": {
      "description": "System settings",
      "allowed_actions": ["read", "update", "manage"]
    },
    "audit_logs": {
      "description": "Audit trail",
      "allowed_actions": ["read", "list", "download"]
    }
  },

  "permission_dependencies": {
    "manage:dashboard":  ["read:dashboard"],
    "delete:orders":     ["read:orders", "list:orders"],
    "approve:orders":    ["read:orders"],
    "assign:orders":     ["read:orders", "list:orders"],
    "archive:orders":    ["read:orders", "list:orders"],
    "download:orders":   ["read:orders"],
    "delete:invoices":   ["read:invoices", "list:invoices"],
    "approve:invoices":  ["read:invoices"],
    "download:invoices": ["read:invoices"],
    "upload:reports":    ["read:reports", "create:reports"],
    "download:reports":  ["read:reports"],
    "delete:reports":    ["read:reports", "list:reports"],
    "upload:documents":  ["read:documents", "create:documents"],
    "download:documents":["read:documents"],
    "delete:documents":  ["read:documents", "list:documents"],
    "archive:documents": ["read:documents", "list:documents"],
    "manage:projects":   ["read:projects", "list:projects", "create:projects", "update:projects"],
    "archive:projects":  ["read:projects", "list:projects"],
    "manage:users":      ["read:users", "list:users", "create:users", "update:users"],
    "assign:users":      ["read:users", "list:users"],
    "manage:settings":   ["read:settings", "update:settings"],
    "download:audit_logs":["read:audit_logs", "list:audit_logs"]
  },

  "roles": {
    "viewer": {
      "description": "Read-only access across the system",
      "inherits": [],
      "permissions": {
        "dashboard":  ["read"],
        "orders":     ["read", "list"],
        "invoices":   ["read", "list"],
        "reports":    ["read", "list"],
        "documents":  ["read", "list"],
        "projects":   ["read", "list"]
      }
    },
    "contributor": {
      "description": "Can create and edit content",
      "inherits": ["viewer"],
      "permissions": {
        "orders":     ["create", "update"],
        "reports":    ["create", "update"],
        "documents":  ["create", "update", "upload", "download"]
      }
    },
    "editor": {
      "description": "Full content management including deletion and downloads",
      "inherits": ["contributor"],
      "permissions": {
        "orders":     ["delete", "download", "archive"],
        "invoices":   ["create", "update", "download"],
        "reports":    ["delete", "upload", "download"],
        "documents":  ["delete", "archive"]
      }
    },
    "approver": {
      "description": "Can approve orders and invoices",
      "inherits": [],
      "permissions": {
        "orders":     ["read", "list", "approve"],
        "invoices":   ["read", "list", "approve"]
      }
    },
    "user_manager": {
      "description": "Can manage user accounts",
      "inherits": [],
      "permissions": {
        "users":      ["read", "list", "create", "update", "assign"]
      }
    },
    "manager": {
      "description": "Editor + approver + user management + reporting",
      "inherits": ["editor", "approver", "user_manager"],
      "permissions": {
        "dashboard":   ["manage"],
        "projects":    ["create", "update", "archive"],
        "audit_logs":  ["read", "list"]
      }
    },
    "admin": {
      "description": "Full system access",
      "inherits": ["manager"],
      "permissions": {
        "users":       ["delete", "manage"],
        "settings":    ["read", "update", "manage"],
        "projects":    ["delete", "manage"],
        "audit_logs":  ["download"],
        "invoices":    ["delete"]
      }
    },
    "auditor": {
      "description": "Read-only access to everything including audit trail",
      "inherits": ["viewer"],
      "permissions": {
        "users":       ["read", "list"],
        "settings":    ["read"],
        "audit_logs":  ["read", "list", "download"],
        "invoices":    ["read", "list", "download"],
        "orders":      ["download"],
        "reports":     ["download"],
        "documents":   ["download"]
      }
    }
  },

  "users": {
    "alice": {
      "display_name": "Alice Johnson",
      "email": "alice@company.com",
      "roles": ["admin"],
      "grants": {},
      "exclusions": {},
      "reports_to": null
    },
    "bob": {
      "display_name": "Bob Smith",
      "email": "bob@company.com",
      "roles": ["manager"],
      "grants": {},
      "exclusions": {
        "users": ["delete"]
      },
      "reports_to": "alice"
    },
    "carol": {
      "display_name": "Carol Williams",
      "email": "carol@company.com",
      "roles": ["editor"],
      "grants": {
        "audit_logs": ["read", "list"]
      },
      "exclusions": {},
      "reports_to": "bob"
    },
    "dave": {
      "display_name": "Dave Brown",
      "email": "dave@company.com",
      "roles": ["contributor"],
      "grants": {},
      "exclusions": {
        "orders": ["delete"]
      },
      "reports_to": "bob"
    },
    "eve": {
      "display_name": "Eve Davis",
      "email": "eve@company.com",
      "roles": ["viewer"],
      "grants": {},
      "exclusions": {},
      "reports_to": "carol"
    },
    "frank": {
      "display_name": "Frank Miller",
      "email": "frank@company.com",
      "roles": ["auditor"],
      "grants": {},
      "exclusions": {},
      "reports_to": "alice"
    },
    "grace": {
      "display_name": "Grace Wilson",
      "email": "grace@company.com",
      "roles": ["contributor", "approver"],
      "grants": {
        "settings": ["read"]
      },
      "exclusions": {
        "documents": ["upload"]
      },
      "reports_to": "bob"
    }
  }
}
